@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix aief:   <https://w3id.org/aief/> .
@prefix aiefsh: <https://w3id.org/aief/shapes#> .

#################################################################
# AIEF SHACL Risk-Dimension Shapes — prototype demonstrator
#
# Each shape is one scrutable risk rule. A rule declares, AS DATA:
#   - the risk dimension it belongs to (an EU Charter right IRI)
#   - its priority rank (aiefsh:priority — an editable integer)
#   - its severity tier (sh:severity — editable: Violation/Warning/Info)
#   - its rationale (rdfs:comment — why this pattern ranks where it does)
#   - the pattern it detects (a SPARQL constraint — inspectable, editable)
#
# An evaluator who disagrees with a priority changes one triple and
# re-validates: the ranking is consistent, observable, and scrutable.
# No LLM is involved in this layer.
#
# Priority provenance: defaults are informed by harm-evidenced-priorities.ttl
# (incident in-degree / max, tiered into thirds). Where aiefsh:priority
# diverges from aiefsh:evidencedPriority, the rationale below records why.
#################################################################

aiefsh: a owl:Ontology ;
    rdfs:label "AIEF risk-dimension shapes (prototype)" ;
    rdfs:comment "SHACL constraint set expressing per-dimension, priority-ranked risk rules over AIEF proposal descriptions. Demonstrates scrutable, evaluator-editable risk prioritisation as an alternative to a single aggregated risk label." ;
    sh:declare [ sh:prefix "aief" ; sh:namespace "https://w3id.org/aief/"^^xsd:anyURI ] .

#################################################################
# Rule 1 — Biometric data without opt-in consent
#################################################################
aiefsh:BiometricConsentShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Biometric data requires opt-in consent" ;
    rdfs:comment "Rationale for priority 1 (deliberate divergence from evidencedPriority 2 for Art8): biometric identifiers are special-category data (GDPR Art. 9) whose collection without opt-in consent is a per-se infringement, not a contextual risk. Corresponds to REAMS consent requirements (R019, R042) and EU AI Act biometric provisions." ;
    aiefsh:riskDimension aief:Art8_DataProtection ;
    aiefsh:priority 1 ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "Biometric data is processed without an opt-in consent mechanism (dimension: Art 8 Data Protection)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:involvesDataCategory aief:BiometricData .
                FILTER NOT EXISTS { $this aief:hasConsentMechanism true }
            }
        """ ;
    ] .

#################################################################
# Rule 2 — Special-category data without a DPIA
#################################################################
aiefsh:DPIAShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Special-category data requires a DPIA" ;
    rdfs:comment "Rationale for priority 1 (deliberate divergence from evidencedPriority 2 for Art8): GDPR Art. 35 makes a Data Protection Impact Assessment mandatory, not advisory, for high-risk processing of special-category data (health, biometric). Absence is a compliance gap independent of how carefully the data is otherwise handled." ;
    aiefsh:riskDimension aief:Art8_DataProtection ;
    aiefsh:priority 1 ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "Special-category data (biometric/health) is processed without a Data Protection Impact Assessment (dimension: Art 8 Data Protection)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:involvesDataCategory ?cat .
                FILTER(?cat IN (aief:BiometricData, aief:HealthData, aief:SpecialCategoryData))
                FILTER NOT EXISTS { $this aief:hasDPIA true }
            }
        """ ;
    ] .

#################################################################
# Rule 3 — Demographic-impact model without independent bias audit
#################################################################
aiefsh:BiasAuditShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Models affecting people require an independent bias audit" ;
    rdfs:comment "Rationale for priority 2 (deliberate divergence from evidencedPriority 1 for Art21 — the most harm-evidenced right at 37 incidents): unaudited demographic bias is a substantive harm channel but, unlike Rules 1-2, is remediable within the project by commissioning an audit before deployment; it therefore ranks below the per-se legal infringements. An evaluator who prioritises discrimination harm can raise aiefsh:priority to 1 and re-validate." ;
    aiefsh:riskDimension aief:Art21_NonDiscrimination ;
    aiefsh:priority 2 ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "A model that makes or informs decisions about people has no independent demographic bias audit (dimension: Art 21 Non-Discrimination)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability ?cap .
                FILTER(?cap IN (aief:FacialRecognition, aief:ClinicalDecisionSupport, aief:AutomatedScreening))
                FILTER NOT EXISTS { $this aief:hasBiasAudit true }
            }
        """ ;
    ] .

#################################################################
# Rule 4 — Monitoring of minors without individual opt-out
#################################################################
aiefsh:ChildrenMonitoringShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Monitoring of minors requires an individual opt-out" ;
    rdfs:comment "Rationale for priority 1 (deliberate divergence from evidencedPriority 3 for Art24): children cannot meaningfully consent through proxies alone; continuous monitoring without an individual opt-out removes the child's own agency entirely. Charter Art. 24 gives children's rights primacy over research convenience, outweighing the thinner incident in-degree (7). Phase 4 audit (Jul 2026): trigger broadened to FacialRecognition and EmotionRecognition involving children — the P06 classroom pattern — because ContinuousMonitoring alone was too narrow and missed camera-based emotion systems." ;
    aiefsh:riskDimension aief:Art24_RightsOfChild ;
    aiefsh:priority 1 ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "Minors are subject to continuous monitoring / biometric emotion or facial analysis with no individual opt-out mechanism (dimension: Art 24 Rights of the Child)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:involvesPopulation aief:Children ;
                      aief:usesCapability ?cap .
                FILTER(?cap IN (aief:ContinuousMonitoring, aief:FacialRecognition, aief:EmotionRecognition))
                FILTER NOT EXISTS { $this aief:hasIndividualOptOut true }
            }
        """ ;
    ] .

#################################################################
# Rule 5 — Clinical decision support without clinical validation
#################################################################
aiefsh:ClinicalValidationShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Clinical decision support requires clinical validation" ;
    rdfs:comment "Rationale for priority 2 (mild divergence from evidencedPriority 3 for Art35): professional oversight partially mitigates unvalidated clinical AI, but the Epic Sepsis Model case (Wong et al. 2021) shows alert fatigue can defeat that oversight, so this is a genuine risk dimension rather than a formality. An evaluator who weighs clinical risk more heavily can raise sh:severity to sh:Violation and re-validate." ;
    aiefsh:riskDimension aief:Art35_HealthCare ;
    aiefsh:priority 2 ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "A clinical decision-support capability has no planned clinical validation (dimension: Art 35 Health Care)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability aief:ClinicalDecisionSupport .
                FILTER NOT EXISTS { $this aief:hasClinicalValidation true }
            }
        """ ;
    ] .

#################################################################
# Rule 6 — Undisclosed AI interaction
#################################################################
aiefsh:AIDisclosureShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Users must know they are interacting with an AI system" ;
    rdfs:comment "Rationale for priority 3 (deliberate divergence from evidencedPriority 2 for Art1): non-disclosure undermines dignity and autonomy (Horizon Europe HE021, EU AI Act transparency provisions) but is trivially remediable by adding a disclosure, so it ranks below structural risks despite substantial incident evidence (21)." ;
    aiefsh:riskDimension aief:Art1_HumanDignity ;
    aiefsh:priority 3 ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "End-users interact with an AI system without disclosure that it is an AI system (dimension: Art 1 Human Dignity)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability aief:ConversationalAgent .
                FILTER NOT EXISTS { $this aief:disclosesAIUse true }
            }
        """ ;
    ] .

#################################################################
# Rules 7-20 — Week-2 widening (16 July 2026)
# Added to cover the remaining Charter dimensions present in the KG,
# converting the RQ2 architecture comparison from a 4-dimension demo
# into a comparison spanning ~20 of the 22 dimensions actually mapped
# by requirements/incidents. Two dimensions (Art13 Freedom of Arts and
# Science, Art20 Equality Before the Law) are deliberately left unruled:
# no reliable text signal distinguishes them from adjacent, already-ruled
# dimensions (Art11 expression; Art21 non-discrimination respectively)
# without a much richer NLU layer than the keyword bridge supports --
# an honest scope limit, not an oversight.
#################################################################

aiefsh:LibertyShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Criminal justice risk-scoring requires effective-remedy safeguards" ;
    rdfs:comment "Rationale for priority 1: liberty-affecting decisions (bail, parole, sentencing) informed by automated risk scores implicate the presumption of innocence and the right to liberty directly; absence of an appeal mechanism compounds the risk (Art 6, Art 47, Art 48)." ;
    aiefsh:riskDimension aief:Art6_RightToLiberty ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "Criminal-justice risk scoring or liberty-affecting decisions with no appeal mechanism (dimension: Art 6 Liberty)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability ?c . FILTER(?c IN (aief:CriminalJusticeRiskScoring, aief:LibertyAffectingDecision))
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

aiefsh:PresumptionOfInnocenceShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Pre-conviction risk scoring requires human oversight" ;
    rdfs:comment "Rationale for priority 1: using AI risk scores before conviction/adjudication risks treating predicted risk as established fact, undermining the presumption of innocence." ;
    aiefsh:riskDimension aief:Art48_PresumptionOfInnocence ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "Criminal-justice risk scoring is used without a stated human-oversight/appeal safeguard (dimension: Art 48 Presumption of Innocence)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:CriminalJusticeRiskScoring .
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

aiefsh:EffectiveRemedyShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Automated decisions affecting people require an appeal mechanism" ;
    rdfs:comment "Rationale for priority 2: any automated decision materially affecting a person (screening, liberty, public-sector) without a contestation route denies effective remedy, but is remediable by adding an appeal process -- ranks below the per-se liberty/innocence violations above." ;
    aiefsh:riskDimension aief:Art47_RightToEffectiveRemedy ;
    aiefsh:priority 2 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "An automated decision affecting people has no appeal mechanism (dimension: Art 47 Effective Remedy)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability ?c . FILTER(?c IN (aief:AutomatedScreening, aief:PublicSectorDecision, aief:LibertyAffectingDecision))
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

aiefsh:SafetyCriticalShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Safety-critical control systems require independent validation" ;
    rdfs:comment "Rationale for priority 1: autonomous control of physical safety-critical systems risks the right to life itself if unvalidated; no remediation short of validation is adequate." ;
    aiefsh:riskDimension aief:Art2_RightToLife ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "A safety-critical control capability has no stated independent validation (dimension: Art 2 Right to Life)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:SafetyCriticalControl .
            FILTER NOT EXISTS { $this aief:hasClinicalValidation true } }""" ; ] .

aiefsh:IntegrityShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Invasive interventions require independent ethical/clinical validation" ;
    rdfs:comment "Rationale for priority 1: neural interfaces, human enhancement and invasive human experimentation implicate bodily integrity directly and are per-se risks absent independent review." ;
    aiefsh:riskDimension aief:Art3_RightToIntegrity ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "An invasive intervention capability has no stated independent validation (dimension: Art 3 Integrity)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:InvasiveIntervention .
            FILTER NOT EXISTS { $this aief:hasClinicalValidation true } }""" ; ] .

aiefsh:PrivacyShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Continuous monitoring requires a stated privacy safeguard" ;
    rdfs:comment "Rationale for priority 2: continuous monitoring/surveillance without consent or DPIA implicates private life distinctly from the data-protection rules above, since Art 7 concerns the intrusion itself rather than the data handling; remediable via consent or an opt-out." ;
    aiefsh:riskDimension aief:Art7_PrivateLife ;
    aiefsh:priority 2 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "Continuous monitoring is used with no consent mechanism or individual opt-out stated (dimension: Art 7 Private Life)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:ContinuousMonitoring .
            FILTER NOT EXISTS { $this aief:hasConsentMechanism true } FILTER NOT EXISTS { $this aief:hasIndividualOptOut true } }""" ; ] .

aiefsh:ExpressionShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Content moderation requires an appeal mechanism" ;
    rdfs:comment "Rationale for priority 2: automated content removal without contestation risks freedom of expression; remediable by adding an appeal route, so ranks below per-se violations." ;
    aiefsh:riskDimension aief:Art11_FreedomOfExpression ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "Content moderation is used with no appeal mechanism stated (dimension: Art 11 Freedom of Expression)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:ContentModeration .
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

aiefsh:OccupationShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Automated hiring/screening requires a bias audit" ;
    rdfs:comment "Rationale for priority 2: automated employment screening risks the freedom to choose an occupation through unaudited exclusionary bias; overlaps partially with the non-discrimination rule but targets the occupational-access dimension specifically." ;
    aiefsh:riskDimension aief:Art15_FreedomOfOccupation ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "Automated hiring/screening has no independent bias audit stated (dimension: Art 15 Freedom of Occupation)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:AutomatedScreening .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true } }""" ; ] .

aiefsh:PropertyShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Training data use requires licensing/rightsholder consent" ;
    rdfs:comment "Rationale for priority 2: unlicensed use of scraped or copyrighted material for training implicates the right to property (IP); remediable by securing licensing." ;
    aiefsh:riskDimension aief:Art17_RightToProperty ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "Unlicensed data use has no stated data licensing arrangement (dimension: Art 17 Right to Property)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:UnlicensedDataUse .
            FILTER NOT EXISTS { $this aief:hasDataLicensing true } }""" ; ] .

aiefsh:CulturalDiversityShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Language technologies require bias auditing across languages" ;
    rdfs:comment "Rationale for priority 3: language/translation systems that underperform on minority languages risk cultural diversity; a Warning tier since the harm is typically one of degraded quality rather than a per-se rights violation." ;
    aiefsh:riskDimension aief:Art22_CulturalDiversity ;
    aiefsh:priority 3 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "Language-processing capability has no stated bias audit across languages/dialects (dimension: Art 22 Cultural Diversity)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:LanguageProcessing .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true } }""" ; ] .

aiefsh:GenderEqualityShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Proposals involving gender-relevant populations require a bias audit" ;
    rdfs:comment "Rationale for priority 2: gender-differentiated impact (e.g. Amazon hiring precedent) requires explicit auditing distinct from general non-discrimination, since gender bias in training data is a documented, specific failure mode." ;
    aiefsh:riskDimension aief:Art23_GenderEquality ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "A proposal involving gender-relevant populations/capabilities has no stated bias audit (dimension: Art 23 Gender Equality)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:involvesPopulation aief:GenderMinorities .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true } }""" ; ] .

aiefsh:DisabilityShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Proposals involving people with disabilities require accessibility design" ;
    rdfs:comment "Rationale for priority 2: systems affecting disabled populations without stated accessibility design (e.g. WCAG compliance) risk exclusion contrary to Art 26 disability integration." ;
    aiefsh:riskDimension aief:Art26_DisabilityIntegration ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "A proposal involving people with disabilities has no stated accessibility design (dimension: Art 26 Disability Integration)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:involvesPopulation aief:PeopleWithDisabilities .
            FILTER NOT EXISTS { $this aief:hasAccessibilityDesign true } }""" ; ] .

aiefsh:WorkingConditionsShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Workplace monitoring requires a consent mechanism" ;
    rdfs:comment "Rationale for priority 2: worker surveillance/productivity monitoring without consent risks fair working conditions (Art 31); remediable via a disclosed consent process." ;
    aiefsh:riskDimension aief:Art31_FairWorkingConditions ;
    aiefsh:priority 2 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "Workplace monitoring has no stated worker consent mechanism (dimension: Art 31 Fair Working Conditions)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:WorkplaceMonitoring .
            FILTER NOT EXISTS { $this aief:hasConsentMechanism true } }""" ; ] .

aiefsh:EnvironmentShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "High-compute training requires an environmental impact assessment" ;
    rdfs:comment "Rationale for priority 3: large-scale compute has an environmental footprint (Art 37); Warning tier since this is a disclosure/accounting obligation rather than a direct rights infringement." ;
    aiefsh:riskDimension aief:Art37_EnvironmentalProtection ;
    aiefsh:priority 3 ; sh:severity sh:Warning ;
    sh:sparql [ sh:message "A high-compute training capability has no stated environmental impact assessment (dimension: Art 37 Environmental Protection)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:HighComputeTraining .
            FILTER NOT EXISTS { $this aief:hasEnvironmentalAssessment true } }""" ; ] .

aiefsh:GoodAdministrationShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Public-sector automated decisions require human review" ;
    rdfs:comment "Rationale for priority 1: public authorities using automated decision-making without human review or an appeal route directly undermines the right to good administration (Art 41), a foundational rule-of-law concern for state action specifically." ;
    aiefsh:riskDimension aief:Art41_GoodAdministration ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "A public-sector automated decision capability has no stated human review/appeal mechanism (dimension: Art 41 Good Administration)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE { $this aief:usesCapability aief:PublicSectorDecision .
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

#################################################################
# Rules 22-27 — Compound/composable escalation rules (16 July 2026)
#
# All rules above fire on a single missing condition. Real ethics risk is
# often conjunctive: several individually-Warning-tier facts combine into
# a Violation-tier concern that no atomic rule captures. Each compound rule
# declares aiefsh:compoundConditions listing the contributing dimensions,
# so the composition itself -- not just the final verdict -- is inspectable
# and auditable, unlike an LLM's internal aggregation of the same facts.
#################################################################

aiefsh:ChildSurveillanceCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Children + continuous monitoring + no safeguards" ;
    rdfs:comment "Individually, monitoring-without-opt-out (Art 7, priority 2) and involving children (Art 24) are each Warning/Priority-2 concerns. Their conjunction is escalated to priority 1 Violation: a child population removes the possibility of meaningful individual consent that would otherwise mitigate a monitoring concern, so the two facts are not merely additive but multiplicative." ;
    aiefsh:riskDimension aief:Art24_RightsOfChild ;
    aiefsh:compoundConditions (aief:Art24_RightsOfChild aief:Art7_PrivateLife) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] Children are subject to continuous monitoring with neither consent nor an individual opt-out (dimensions: Art 24 + Art 7, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:involvesPopulation aief:Children ; aief:usesCapability aief:ContinuousMonitoring .
            FILTER NOT EXISTS { $this aief:hasConsentMechanism true }
            FILTER NOT EXISTS { $this aief:hasIndividualOptOut true } }""" ; ] .

aiefsh:BiometricPublicSectorCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Biometric identification by a public authority, unaudited" ;
    rdfs:comment "Facial recognition alone (Art 8/21, priority 1-2) and public-sector deployment alone (Art 41, priority 1) are each serious but separately remediable. Combined with the absence of a bias audit, state-actor biometric identification compounds data protection, non-discrimination, and rule-of-law concerns simultaneously -- escalated above any single contributing rule." ;
    aiefsh:riskDimension aief:Art21_NonDiscrimination ;
    aiefsh:compoundConditions (aief:Art8_DataProtection aief:Art21_NonDiscrimination aief:Art41_GoodAdministration) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] A public-sector actor uses unaudited facial recognition (dimensions: Art 8 + Art 21 + Art 41, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:usesCapability aief:FacialRecognition, aief:PublicSectorDecision .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true } }""" ; ] .

aiefsh:VulnerableHealthCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Unvalidated clinical decision support for children" ;
    rdfs:comment "Clinical decision support without validation (Art 35, priority 2 Warning) is remediable by validation alone when the affected population is adults. When the population is children, the same gap compounds with Art 24: paediatric clinical error has materially different, less reversible consequences, escalating from Warning to Violation." ;
    aiefsh:riskDimension aief:Art35_HealthCare ;
    aiefsh:compoundConditions (aief:Art35_HealthCare aief:Art24_RightsOfChild) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] Unvalidated clinical decision support is applied to a child population (dimensions: Art 35 + Art 24, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:usesCapability aief:ClinicalDecisionSupport ; aief:involvesPopulation aief:Children .
            FILTER NOT EXISTS { $this aief:hasClinicalValidation true } }""" ; ] .

aiefsh:CriminalJusticeTripleCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Unaudited, unappealable criminal-justice risk scoring" ;
    rdfs:comment "This is the maximal compound case in the rule set: criminal-justice risk scoring (Art 6, Art 48) that is both unaudited for bias (Art 21) and has no appeal route (Art 47) implicates four dimensions simultaneously. Any one gap alone is priority 1-2; their conjunction represents the highest-priority compound pattern the rule set expresses, directly modelling the COMPAS-type failure mode in the incident corpus." ;
    aiefsh:riskDimension aief:Art48_PresumptionOfInnocence ;
    aiefsh:compoundConditions (aief:Art6_RightToLiberty aief:Art21_NonDiscrimination aief:Art47_RightToEffectiveRemedy aief:Art48_PresumptionOfInnocence) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] Criminal-justice risk scoring is unaudited for bias and has no appeal mechanism (dimensions: Art 6 + Art 21 + Art 47 + Art 48, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:usesCapability aief:CriminalJusticeRiskScoring .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true }
            FILTER NOT EXISTS { $this aief:hasAppealMechanism true } }""" ; ] .

aiefsh:GenderHiringCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Automated screening of gender-relevant populations, unaudited" ;
    rdfs:comment "Automated screening alone (Art 15, priority 2) and gender-relevant populations alone (Art 23, priority 2) are each Warning-tier. Combined -- the Amazon hiring-algorithm pattern precisely -- unaudited screening with disparate gender impact is escalated to Violation, since this is a documented, repeated real-world failure mode rather than a hypothetical compounding." ;
    aiefsh:riskDimension aief:Art23_GenderEquality ;
    aiefsh:compoundConditions (aief:Art15_FreedomOfOccupation aief:Art23_GenderEquality) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] Automated screening affecting gender-relevant populations has no bias audit (dimensions: Art 15 + Art 23, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:usesCapability aief:AutomatedScreening ; aief:involvesPopulation aief:GenderMinorities .
            FILTER NOT EXISTS { $this aief:hasBiasAudit true } }""" ; ] .

aiefsh:UnlicensedHighComputeCompoundShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "[Compound] Large-scale training on unlicensed data" ;
    rdfs:comment "High-compute training alone (Art 37, priority 3, an accounting obligation) and unlicensed data use alone (Art 17, priority 2) are each moderate. Combined, large-scale unlicensed data use has materially higher stakes -- the harm from unresolved IP infringement or environmental cost scales with training run size -- so the conjunction escalates by one priority tier relative to either individual rule." ;
    aiefsh:riskDimension aief:Art17_RightToProperty ;
    aiefsh:compoundConditions (aief:Art17_RightToProperty aief:Art37_EnvironmentalProtection) ;
    aiefsh:priority 1 ; sh:severity sh:Violation ;
    sh:sparql [ sh:message "[COMPOUND] Large-scale (high-compute) training uses unlicensed data with no licensing arrangement stated (dimensions: Art 17 + Art 37, compounded)." ;
        sh:prefixes aiefsh: ;
        sh:select """SELECT $this WHERE {
            $this aief:usesCapability aief:HighComputeTraining, aief:UnlicensedDataUse .
            FILTER NOT EXISTS { $this aief:hasDataLicensing true } }""" ; ] .

#################################################################
# Phase 4 — Transparency / Sustainability / Assembly shapes
# (Jul 2026). These are deliberate complements to the LLM RAG arm:
# SHACL catches structural omissions (disclosure, environmental
# accounting, assembly chilling) that free-text assessment often
# crowds out with bias/privacy. Finding for RQ2: these flags are
# intended for the standalone SHACL-vs-LLM comparison arm, and are
# also available to feed the LLM prompt if desired.
#################################################################

aiefsh:TransparencyDisclosureShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "End-user AI interaction requires explicit AI disclosure" ;
    rdfs:comment "Phase 4 addition. Broader than AIDisclosureShape (ConversationalAgent-only): any end-user-facing AI capability without disclosed AI use is a transparency gap. Risk dimension is Art 47 Effective Remedy (not Art 41) to avoid compounding the over-injection of Good Administration already observed in keyword retrieval. Warning tier — remediable by adding disclosure." ;
    aiefsh:riskDimension aief:Art47_RightToEffectiveRemedy ;
    aiefsh:priority 3 ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "An end-user-facing AI capability is present with no explicit AI-disclosure / explainability provision (dimension: Art 47 Effective Remedy — transparency)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability ?cap .
                FILTER(?cap IN (aief:EndUserFacingAI, aief:ConversationalAgent, aief:EmotionRecognition, aief:ClinicalDecisionSupport))
                FILTER NOT EXISTS { $this aief:disclosesAIUse true }
                FILTER NOT EXISTS { $this aief:hasExplainabilityProvision true }
            }
        """ ;
    ] .

aiefsh:SustainabilityDisclosureShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Large-scale training/deployment requires an environmental-impact statement" ;
    rdfs:comment "Phase 4 addition. Complements EnvironmentShape (HighComputeTraining-only) by also firing on LargeScaleDeployment and LargeDatasetTraining capability flags produced by the text bridge when proposals claim large datasets / compute without an environmental impact statement. Targets Art 37." ;
    aiefsh:riskDimension aief:Art37_EnvironmentalProtection ;
    aiefsh:priority 3 ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "Large-scale model training or deployment is claimed with no environmental-impact statement (dimension: Art 37 Environmental Protection)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability ?cap .
                FILTER(?cap IN (aief:HighComputeTraining, aief:LargeScaleDeployment, aief:LargeDatasetTraining))
                FILTER NOT EXISTS { $this aief:hasEnvironmentalAssessment true }
            }
        """ ;
    ] .

aiefsh:AssemblyAssociationShape a sh:NodeShape ;
    sh:targetClass aief:ResearchProposal ;
    rdfs:label "Monitoring of collective/group activity implicates freedom of assembly" ;
    rdfs:comment "Phase 4 addition (requires Art12_FreedomOfAssembly from Phase 0). Triggers when a proposal involves monitoring of protest, union, or assembly contexts without stated safeguards for peaceful assembly/association. Warning tier — the chilling-effect risk is real but remediable via purpose limitation and oversight." ;
    aiefsh:riskDimension aief:Art12_FreedomOfAssembly ;
    aiefsh:priority 2 ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "Collective/group activity (protest, assembly, organising) is monitored or classified without stated assembly/association safeguards (dimension: Art 12 Freedom of Assembly)." ;
        sh:prefixes aiefsh: ;
        sh:select """
            SELECT $this WHERE {
                $this aief:usesCapability aief:CollectiveActivityMonitoring .
                FILTER NOT EXISTS { $this aief:hasAssemblySafeguard true }
            }
        """ ;
    ] .
