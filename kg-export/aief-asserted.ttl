@prefix agg: <http://jena.apache.org/ARQ/function/aggregate#> .
@prefix : <http://example.org/ai-ethics#> .
@prefix sail: <http://www.openrdf.org/config/sail#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix geof: <http://www.opengis.net/def/function/geosparql/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix fn: <http://www.w3.org/2005/xpath-functions> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spif: <http://spinrdf.org/spif#> .
@prefix path: <http://www.ontotext.com/path#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix array: <http://www.w3.org/2005/xpath-functions/array> .
@prefix apf: <http://jena.apache.org/ARQ/property#> .
@prefix rep: <http://www.openrdf.org/config/repository#> .
@prefix map: <http://www.w3.org/2005/xpath-functions/map> .
@prefix sr: <http://www.openrdf.org/config/repository/sail#> .
@prefix wgs: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix gn: <http://www.geonames.org/ontology#> .
@prefix afn: <http://jena.apache.org/ARQ/function#> .
@prefix list: <http://jena.apache.org/ARQ/list#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ofn: <http://www.ontotext.com/sparql/functions/> .
@prefix geoext: <http://rdf.useekm.com/ext#> .
@prefix eu-rights: <https://w3c-cg.github.io/dpv/2.3/legal/eu/rights#> .
@prefix graphdb: <http://www.ontotext.com/config/graphdb#> .
@prefix math: <http://www.w3.org/2005/xpath-functions/math> .
@prefix omgeo: <http://www.ontotext.com/owlim/geo#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .

<https://w3id.org/aief/> a owl:Ontology;
  rdfs:comment "Ontology for multi-framework AI ethics compliance assessment";
  rdfs:label "AI-Assisted Ethics Assessment Framework" .

<https://w3id.org/aief/Framework> a owl:Class;
  rdfs:comment "A governance or regulatory framework defining ethics requirements for AI research.";
  rdfs:label "Governance Framework" .

<https://w3id.org/aief/Requirement> a owl:Class;
  rdfs:comment "A normative statement derived from a governance framework specifying what a researcher must, may, or must not do.";
  rdfs:label "Ethics Requirement" .

<https://w3id.org/aief/Tier> a owl:Class;
  rdfs:comment "Classification of a requirement by its conditionality. Tier 1 requirements are mandatory for all research proposals. Tier 2 requirements are reflective prompts that apply conditionally based on research context.";
  rdfs:label "Assessment Tier" .

<https://w3id.org/aief/EUCharterRight> a owl:Class;
  rdfs:comment "A fundamental right protected under the Charter of Fundamental Rights of the European Union (2000/C 364/01).";
  rdfs:label "EU Charter of Fundamental Rights Article";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Stakeholder> a owl:Class;
  rdfs:comment "An individual or organisational role involved in the research ethics assessment process.";
  rdfs:label "Stakeholder" .

<https://w3id.org/aief/Evidence> a owl:Class;
  rdfs:comment "A document or artefact that demonstrates compliance with an ethics requirement.";
  rdfs:label "Ethics Evidence Document" .

<https://w3id.org/aief/RiskCategory> a owl:Class;
  rdfs:comment "A category of harm or risk that an AI system may cause to individuals, groups, or society.";
  rdfs:label "Risk Category" .

<https://w3id.org/aief/DataCategory> a owl:Class;
  rdfs:comment "A classification of personal or research data relevant to ethics assessment, aligned with GDPR data categories.";
  rdfs:label "Data Category";
  dct:source <https://gdpr-info.eu/art-9-gdpr/> .

<https://w3id.org/aief/Mitigation> a owl:Class;
  rdfs:comment "A technical or organisational measure that reduces the likelihood or severity of an identified risk.";
  rdfs:label "Mitigation Measure" .

<https://w3id.org/aief/AssessmentProcess> a owl:Class;
  rdfs:comment "A formal procedure for evaluating ethics compliance, risk, or impact of a research project or AI system.";
  rdfs:label "Assessment Process" .

<https://w3id.org/aief/ComplianceStatus> a owl:Class;
  rdfs:comment "The compliance state of a requirement within a given research project assessment.";
  rdfs:label "Compliance Status" .

<https://w3id.org/aief/REAMS> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Framework>;
  rdfs:comment "Trinity College Dublin Research Ethics Application Management System. Institutional ethics framework for research approval.";
  rdfs:label "TCD REAMS";
  dct:source <https://www.tcd.ie/research/ethics/> .

<https://w3id.org/aief/EUAIAct> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Framework>;
  rdfs:comment "Regulation (EU) 2024/1689 of the European Parliament and of the Council on Artificial Intelligence. FRIA requirements from Article 27.";
  rdfs:label "EU AI Act";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32024R1689> .

<https://w3id.org/aief/HorizonEurope> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Framework>;
  rdfs:comment "European Commission ethics requirements for Horizon Europe funded research projects.";
  rdfs:label "Horizon Europe", "Horizon Europe Ethics Guidelines";
  dct:source <https://ec.europa.eu/info/funding-tenders/opportunities/docs/2021-2027/horizon/guidance/ethics-appraisal-procedure_he_en.pdf> .

<https://w3id.org/aief/ACMConference> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Framework>;
  rdfs:comment "Research ethics and broader impact requirements from ACM, NeurIPS, FAccT, AAAI, and ACL Rolling Review conference submission guidelines.";
  rdfs:label "ACM Conference", "ACM/NeurIPS Research Ethics Guidelines";
  dct:source <https://www.acm.org/code-of-ethics> .

<https://w3id.org/aief/ACLRollingReview> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/ACMConference>;
  rdfs:label "ACL Rolling Review" .

<https://w3id.org/aief/NeurIPS> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/ACMConference>;
  rdfs:label "NeurIPS" .

<https://w3id.org/aief/FAccT> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/ACMConference>;
  rdfs:label "FAccT" .

<https://w3id.org/aief/AAAI> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/ACMConference>;
  rdfs:label "AAAI" .

<https://w3id.org/aief/Obligation> a owl:Class;
  rdfs:subClassOf odrl:Duty, <https://w3id.org/aief/Requirement>;
  rdfs:comment "An ethics requirement that must be fulfilled. Aligned with ODRL Duty.",
    "An ethics requirement specifying an action that must be performed. Aligned with ODRL Duty.";
  rdfs:label "Obligation";
  dct:source <http://www.w3.org/ns/odrl/2/> .

<https://w3id.org/aief/Prohibition> a owl:Class;
  rdfs:subClassOf odrl:Prohibition, <https://w3id.org/aief/Requirement>;
  rdfs:comment "An ethics requirement that forbids a specific action. Aligned with ODRL Prohibition.",
    "An ethics requirement specifying an action that is forbidden. Aligned with ODRL Prohibition.";
  rdfs:label "Prohibition";
  dct:source <http://www.w3.org/ns/odrl/2/> .

<https://w3id.org/aief/Permission> a owl:Class;
  rdfs:subClassOf odrl:Permission, <https://w3id.org/aief/Requirement>;
  rdfs:comment "An ethics requirement that permits a specific action under defined conditions. Aligned with ODRL Permission.",
    "An ethics requirement specifying an action that is permitted under defined conditions. Aligned with ODRL Permission.";
  rdfs:label "Permission";
  dct:source <http://www.w3.org/ns/odrl/2/> .

<https://w3id.org/aief/Tier1_Mandatory> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Tier>;
  rdfs:comment "Requirements that apply to all research proposals regardless of context. Failure to comply blocks ethics approval.";
  rdfs:label "Tier 1 — Mandatory" .

<https://w3id.org/aief/Tier2_Reflective> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Tier>;
  rdfs:comment "Requirements that apply conditionally based on research context. Researchers must reflect on whether these apply to their specific project.";
  rdfs:label "Tier 2 — Reflective" .

<https://w3id.org/aief/Title1_Dignity> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter of Fundamental Rights Title I covering Articles 1–5 on human dignity.";
  rdfs:label "Title I — Dignity";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art1_HumanDignity> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title1_Dignity>;
  owl:equivalentClass eu-rights:HumanDignity;
  rdfs:comment "Human dignity is inviolable. It must be respected and protected.";
  rdfs:label "Article 1 — Human Dignity";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art2_RightToLife> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title1_Dignity>;
  owl:equivalentClass eu-rights:RightToLife;
  rdfs:comment "Everyone has the right to life.";
  rdfs:label "Article 2 — Right to Life";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art3_RightToIntegrity> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title1_Dignity>;
  owl:equivalentClass eu-rights:PersonalIntegrity;
  rdfs:comment "Everyone has the right to respect for his or her physical and mental integrity.";
  rdfs:label "Article 3 — Right to Integrity";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art5_ProhibitionOfSlavery> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title1_Dignity>;
  rdfs:comment "No one shall be held in slavery or servitude.";
  rdfs:label "Article 5 — Prohibition of Slavery";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Title2_Freedoms> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter Title II covering Articles 6–19 on freedoms.";
  rdfs:label "Title II — Freedoms";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art6_RightToLiberty> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  owl:equivalentClass eu-rights:LibertyAndSecurityOfPerson;
  rdfs:comment "Everyone has the right to liberty and security of person.";
  rdfs:label "Article 6 — Right to Liberty and Security";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art7_PrivateLife> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  owl:equivalentClass eu-rights:PrivateLife;
  rdfs:comment "Everyone has the right to respect for his or her private and family life, home and communications.";
  rdfs:label "Article 7 — Respect for Private and Family Life";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art8_DataProtection> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  owl:equivalentClass eu-rights:DataProtection;
  rdfs:comment "Everyone has the right to the protection of personal data concerning him or her.";
  rdfs:label "Article 8 — Protection of Personal Data";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art10_FreedomOfThought> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  rdfs:comment "Everyone has the right to freedom of thought, conscience and religion.";
  rdfs:label "Article 10 — Freedom of Thought";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art11_FreedomOfExpression> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  owl:equivalentClass eu-rights:FreedomOfExpression;
  rdfs:comment "Everyone has the right to freedom of expression. This right shall include freedom to hold opinions and to receive and impart information and ideas without interference by public authority.";
  rdfs:label "Article 11 — Freedom of Expression";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art16_FreedomToConductBusiness> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title2_Freedoms>;
  rdfs:comment "The freedom to conduct a business in accordance with Union law and national laws and practices is recognised.";
  rdfs:label "Article 16 — Freedom to Conduct a Business";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Title3_Equality> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter Title III covering Articles 20–26 on equality.";
  rdfs:label "Title III — Equality";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art20_EqualityBeforeLaw> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  owl:equivalentClass eu-rights:EqualityBeforeLaw;
  rdfs:comment "Everyone is equal before the law.";
  rdfs:label "Article 20 — Equality Before the Law";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art21_NonDiscrimination> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  owl:equivalentClass eu-rights:NonDiscrimination;
  rdfs:comment "Any discrimination based on any ground such as sex, race, colour, ethnic or social origin, genetic features, language, religion or belief, political or any other opinion, membership of a national minority, property, birth, disability, age or sexual orientation shall be prohibited.";
  rdfs:label "Article 21 — Non-Discrimination";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art22_CulturalDiversity> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  rdfs:comment "The Union shall respect cultural, religious and linguistic diversity.";
  rdfs:label "Article 22 — Cultural Diversity";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art23_GenderEquality> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  owl:equivalentClass eu-rights:GenderEquality;
  rdfs:comment "Equality between women and men must be ensured in all areas, including employment, work and pay.";
  rdfs:label "Article 23 — Equality Between Women and Men";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art24_RightsOfChild> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  owl:equivalentClass eu-rights:RightsOfChild;
  rdfs:comment "Children shall have the right to such protection and care as is necessary for their well-being.";
  rdfs:label "Article 24 — Rights of the Child";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art25_RightsOfElderly> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  rdfs:comment "The Union recognises and respects the rights of the elderly to lead a life of dignity and independence.";
  rdfs:label "Article 25 — Rights of the Elderly";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art26_DisabilityIntegration> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title3_Equality>;
  rdfs:comment "The Union recognises and respects the right of persons with disabilities to benefit from measures designed to ensure their independence, social and occupational integration and participation in the life of the community.";
  rdfs:label "Article 26 — Integration of Persons with Disabilities";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Title4_Solidarity> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter Title IV covering Articles 27–38 on solidarity and social rights.";
  rdfs:label "Title IV — Solidarity";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art31_FairWorkingConditions> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title4_Solidarity>;
  rdfs:comment "Every worker has the right to working conditions which respect his or her health, safety and dignity.";
  rdfs:label "Article 31 — Fair and Just Working Conditions";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art35_HealthCare> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title4_Solidarity>;
  owl:equivalentClass eu-rights:HealthCare;
  rdfs:comment "Everyone has the right of access to preventive health care and the right to benefit from medical treatment under the conditions established by national laws and practices.";
  rdfs:label "Article 35 — Health Care";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art37_EnvironmentalProtection> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title4_Solidarity>;
  rdfs:comment "A high level of environmental protection and the improvement of the quality of the environment must be integrated into the policies of the Union.";
  rdfs:label "Article 37 — Environmental Protection";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Title5_CitizensRights> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter Title V covering Articles 39–46 on citizens' rights.";
  rdfs:label "Title V — Citizens' Rights";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art38_ConsumerProtection> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title5_CitizensRights>;
  rdfs:comment "Union policies shall ensure a high level of consumer protection.";
  rdfs:label "Article 38 — Consumer Protection";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art41_GoodAdministration> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title5_CitizensRights>;
  owl:equivalentClass eu-rights:GoodAdministration;
  rdfs:comment "Every person has the right to have his or her affairs handled impartially, fairly and within a reasonable time by the institutions and bodies of the Union.";
  rdfs:label "Article 41 — Right to Good Administration";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Title6_Justice> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/EUCharterRight>;
  rdfs:comment "EU Charter Title VI covering Articles 47–50 on justice.";
  rdfs:label "Title VI — Justice";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Art47_RightToEffectiveRemedy> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Title6_Justice>;
  owl:equivalentClass eu-rights:EffectiveRemedy;
  rdfs:comment "Everyone whose rights and freedoms guaranteed by the law of the Union are violated has the right to an effective remedy before a tribunal.";
  rdfs:label "Article 47 — Right to an Effective Remedy";
  dct:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:12016P/TXT> .

<https://w3id.org/aief/Researcher> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/Supervisor> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/PrincipalInvestigator> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/EthicsCommittee> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/DataSubject> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/Participant> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/Annotator> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/AIDeployer> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/MarketSurveillanceAuthority> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/DataProtectionOfficer> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/FundingBody> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Stakeholder> .

<https://w3id.org/aief/Certificate> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Evidence>;
  rdfs:comment "A formal certificate demonstrating completion of a required training or qualification.";
  rdfs:label "Certificate" .

<https://w3id.org/aief/ConsentForm> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Evidence>;
  rdfs:comment "A document through which research participants provide informed consent to participate.";
  rdfs:label "Consent Form" .

<https://w3id.org/aief/DataProtectionPolicy> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Evidence>;
  rdfs:comment "An organisational policy documenting how personal data is collected, stored, and processed in compliance with GDPR.";
  rdfs:label "Data Protection Policy" .

<https://w3id.org/aief/RiskAssessmentReport> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Evidence>;
  rdfs:comment "A document identifying and evaluating potential harms arising from a research project or AI system.";
  rdfs:label "Risk Assessment Report" .

<https://w3id.org/aief/BiasAssessmentReport> a owl:Class;
  rdfs:subClassOf <https://w3id.org/aief/Evidence>;
  rdfs:comment "A document evaluating the presence and extent of bias in an AI system's training data or outputs.";
  rdfs:label "Bias Assessment Report" .

<https://w3id.org/aief/DPIA> a owl:Class;
